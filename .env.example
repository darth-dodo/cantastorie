# Cantastorie environment configuration
# Copy to .env and fill in values. The .env file is gitignored.
#
# Both keys are used only by the authoring pipeline (and later the Phase 2
# service) — never in the browser, never needed at story time.

# OpenRouter — story writing, safety gate, glosses, images.
OPENROUTER_API_KEY=

# ElevenLabs — narration with character-level timestamps.
ELEVENLABS_API_KEY=
