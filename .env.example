# Cantastorie environment configuration
# Copy to .env and fill in values. The .env file is gitignored.
#
# This key is used only by the authoring pipeline (and later the Phase 2
# service) — never in the browser, never needed at story time.

# OpenRouter — story writing, safety gate, glosses, images, and narration.
OPENROUTER_API_KEY=

# LangSmith — observability/tracing for the pipeline and FastAPI app.
# When LANGSMITH_TRACING is false (or unset), the langsmith package is inert.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cantastorie
