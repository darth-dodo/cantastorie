{
  "rules": [
    {
      "allowed": {
        "origins": ["https://cantastorie.onrender.com", "http://localhost:8000"],
        "methods": ["GET", "HEAD"],
        "headers": ["Range"]
      },
      "exposeHeaders": ["Content-Length", "Content-Range", "ETag", "Content-Type"],
      "maxAgeSeconds": 3600
    }
  ]
}
